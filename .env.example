# ========== 环境变量配置 ==========

# 千问API Key（必填）
QWEN_API_KEY=your-qwen-api-key-here

# 应用密钥（必填，生产环境请更换）
SECRET_KEY=your-secret-key-change-in-production

# ========== 可选配置 ==========

# 千问模型选择
QWEN_MODEL_PLUS=qwen-plus
QWEN_MODEL_TURBO=qwen-turbo

# 初始用户密码（可选，有默认值）
ADMIN_PASSWORD=admin123
VIEWER_PASSWORD=viewer123